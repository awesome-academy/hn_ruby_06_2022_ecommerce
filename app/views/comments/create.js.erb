<% if @comment.save %>
  $("#all-comments").prepend(
    "<%= j (render("shared/book_comment", comment: @comment)) %>"
  );
  $("#comment-area").val("");
  $("#comment-image").val("");
  $("input:radio[name='comment[rate]']").each(function(i) {
    this.checked = false;
  });
  $("#book-info-star").html(
    "<%= j render_star(@comment.book.rate_avg) %>"
  );
<% else %>
  alert(I18n.t("js.error_comment"));
<% end %>
